n Locked="false" Priority="47" Name="List Table 2"/>  <w:LsdException Locked="false" Priority="48" Name="List Table 3"/>  <w:LsdException Locked="false" Priority="49" Name="List Table 4"/>  <w:LsdException Locked="false" Priority="50" Name="List Table 5 Dark"/>  <w:LsdException Locked="false" Priority="51" Name="List Table 6 Colorful"/>  <w:LsdException Locked="false" Priority="52" Name="List Table 7 Colorful"/>  <w:LsdException Locked="false" Priority="46"    Name="List Table 1 Light Accent 1"/>  <w:LsdException Locked="false" Priority="47" Name="List Table 2 Accent 1"/>  <w:LsdException Locked="false" Priority="48" Name="List Table 3 Accent 1"/>  <w:LsdException Locked="false" Priority="49" Name="List Table 4 Accent 1"/>  <w:LsdException Locked="false" Priority="50" Name="List Table 5 Dark Accent 1"/>  <w:LsdException Locked="false" Priority="51"    Name="List Table 6 Colorful Accent 1"/>  <w:LsdException Locked="false" Priority="52"    Name="List Table 7 Colorful Accent 1"/>  <w:LsdException Locked="false" Priority="46"    Name="List Table 1 Light Accent 2"/>  <w:LsdException Locked="false" Priority="47" Name="List Table 2 Accent 2"/>  <w:LsdException Locked="false" Priority="48" Name="List Table 3 Accent 2"/>  <w:LsdException Locked="false" Priority="49" Name="List Table 4 Accent 2"/>  <w:LsdException Locked="false" Priority="50" Name="List Table 5 Dark Accent 2"/>  <w:LsdException Locked="false" Priority="51"    Name="List Table 6 Colorful Accent 2"/>  <w:LsdException Locked="false" Priority="52"    Name="List Table 7 Colorful Accent 2"/>  <w:LsdException Locked="false" Priority="46"    Name="List Table 1 Light Accent 3"/>  <w:LsdException Locked="false" Priority="47" Name="List Table 2 Accent 3"/>  <w:LsdException Locked="false" Priority="48" Name="List Table 3 Accent 3"/>  <w:LsdException Locked="false" Priority="49" Name="List Table 4 Accent 3"/>  <w:LsdException Locked="false" Priority="50" Name="List Table 5 Dark Accent 3"/>  <w:LsdException Locked="false" Priority="51"    Name="List Table 6 Colorful Accent 3"/>  <w:LsdException Locked="false" Priority="52"    Name="List Table 7 Colorful Accent 3"/>  <w:LsdException Locked="false" Priority="46"    Name="List Table 1 Light Accent 4"/>  <w:LsdException Locked="false" Priority="47" Name="List Table 2 Accent 4"/>  <w:LsdException Locked="false" Priority="48" Name="List Table 3 Accent 4"/>  <w:LsdException Locked="false" Priority="49" Name="List Table 4 Accent 4"/>  <w:LsdException Locked="false" Priority="50" Name="List Table 5 Dark Accent 4"/>  <w:LsdException Locked="false" Priority="51"    Name="List Table 6 Colorful Accent 4"/>  <w:LsdException Locked="false" Priority="52"    Name="List Table 7 Colorful Accent 4"/>  <w:LsdException Locked="false" Priority="46"    Name="List Table 1 Light Accent 5"/>  <w:LsdException Locked="false" Priority="47" Name="List Table 2 Accent 5"/>  <w:LsdException Locked="false" Priority="48" Name="List Table 3 Accent 5"/>  <w:LsdException Locked="false" Priority="49" Name="List Table 4 Accent 5"/>  <w:LsdException Locked="false" Priority="50" Name="List Table 5 Dark Accent 5"/>  <w:LsdException Locked="false" Priority="51"    Name="List Table 6 Colorful Accent 5"/>  <w:LsdException Locked="false" Priority="52"    Name="List Table 7 Colorful Accent 5"/>  <w:LsdException Locked="false" Priority="46"    Name="List Table 1 Light Accent 6"/>  <w:LsdException Locked="false" Priority="47" Name="List Table 2 Accent 6"/>  <w:LsdException Locked="false" Priority="48" Name="List Table 3 Accent 6"/>  <w:LsdException Locked="false" Priority="49" Name="List Table 4 Accent 6"/>  <w:LsdException Locked="false" Priority="50" Name="List Table 5 Dark Accent 6"/>  <w:LsdException Locked="false" Priority="51"    Name="List Table 6 Colorful Accent 6"/>  <w:LsdException Locked="false" Priority="52"    Name="List Table 7 Colorful Accent 6"/> </w:LatentStyles></xml><![endif]--><!--[if gte mso 10]><![endif]--> <br /><div></div><div>Dù biết là vẫn mang ý là xóa dữ liệu nhưng ở những trường hợp khác nhau sẽ có ý nghĩa khác nhau. Hôm nay chúng ta đi tìm hiểu ý nghĩa của để biết cách sự dụng cho hợp lý nhé.<br /><br /><br /><div style="clear: both; text-align: center;"><a href="https://www.howtogeek.com/wp-content/uploads/2015/06/00_lead_image_delete_key.png" style="margin-left: 1em; margin-right: 1em;"><img border="0" height="147" src="https://www.howtogeek.com/wp-content/uploads/2015/06/00_lead_image_delete_key.png" width="320" /></a></div></div><div><br /></div><div><b>Delete:</b></div><div>OK Delete thì quá quen rồi nhưng có thật xự file, dữ liệu của bạn sẽ bị mất khi nhấn delete và chọn ok ?<br /><br /><a name='more'></a></div><div><br /></div><div>Thật ra thì nó chỉ ẩn các file đó ở những nơi ko cần thiết mà thôi, nó sẽ được chứa trong Recycle Bin của Windows or Trash của Linux (Android) và bạn dễ dàng vô đó mà tìm lại những gì mà bạn là delete.</div><div>Theo chuyên môn 1 tý thì<span lang="VI" style="mso-ansi-language: VI;"> quá trình </span>delete<span lang="VI" style="mso-ansi-language: VI;"> chỉ đơn giản là cập nhật cơ sở dữ liệu theo dõi các tệp trên đĩa và loại bỏ thông tin vị trí. Nó chỉ đơn giản nói với hệ điều hành rằng không gian bây giờ có sẵn để được ghi trên.</span></div><div>Vì vậy khi bạn muốn delete 1 file, nội dung nhạy cảm nào đó thì nhớ đừng có delete nhé mà hãy nhấn Shift + Delete </div><div><br /></div><div><b>Erase:</b></div><div>Khi nói là Erase nghĩa là chúng ta phải loại bỏ hoàn toàn dữ liệu và không thể phục hồi lại được, đối với những dữ liệu có tính nhạy cảm cao thì sẽ có nhiều cách để xóa, có thể là chép đè dữ liệu 0 và 1 hoặc có thể hủy luôn thiết bị</div><div><br /></div><div><b>Wipe:</b></div><div>Thường các bạn hay vọc smartphone, up ROM, root thì khá quen với từ wipe. Vậy wipe là gì? Vân nó cũng là xóa nhưng mà <span lang="VI" style="mso-ansi-language: VI;">là xóa trên quy mô lớn. Thông thường được sử dụng để loại bỏ tất cả dữ liệu trên ổ đĩa. Họ ghi đè lên mỗi phần của ổ đĩa và đảm bảo rằng ổ đĩa của bạn trở nên “sạch sẽ</span>”<span lang="VI" style="mso-ansi-language: VI;">.</span></div><div><br /></div><div>Nếu bạn muốn quăng cái máy tính của bạn đi hoặc cho ai đó hoặc bán ve chai thì ý tưởng hay nhất là bạn hãy “Wipe” hết mọi thứ trong ổ cứng đi nhé. Format không chưa đủ đâu nhé, <span lang="VI" style="mso-ansi-language: VI;">khi bạn </span>format<span lang="VI" style="mso-ansi-language: VI;"> một ổ đĩa cứng hoặc xóa một </span>partition<span lang="VI" style="mso-ansi-language: VI;">, bạn thường chỉ xóa hệ thống tập tin, làm cho dữ liệu không nhìn thấy đượ</span>c<span lang="VI" style="mso-ansi-language: VI;">, nhưng không biến mất. Chỉ cần dùng 1 vài tool đơn giản là sẽ recovery được dữ liệu của bạn.</span> Nên<span lang="VI" style="mso-ansi-language: VI;"> bạn muốn đảm bảo rằng thông tin cá nhân của bạn đã biến mất mãi mãi, bạn cần </span>Wipe<span lang="VI" style="mso-ansi-language: VI;">.</span></div><div><br /></div><div>Tool đây: HDD Wipe Tool</div><div><span lang="VI" style="mso-ansi-language: VI;">http://hddguru.com/software/2006.04.13-HDD-Wipe-Tool/</span></div>]]></content:encoded>
